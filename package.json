{
  "name": "al-perf",
  "version": "0.1.0",
  "description": "CLI tool and MCP server for analyzing Business Central .alcpuprofile files",
  "type": "module",
  "main": "src/index.ts",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "bin": {
    "al-profile": "src/cli/index.ts",
    "al-profile-mcp": "src/mcp/index.ts"
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.d.ts",
    ".mcp.json"
  ],
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build": "tsc",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "web": "bun run web/server.ts"
  },
  "keywords": ["business-central", "al", "performance", "profiler", "mcp", "alcpuprofile"],
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "marked": "^17.0.3",
    "web-tree-sitter": "^0.26.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "bun-types": "^1.3.9",
    "typescript": "^5.9.3"
  }
}
