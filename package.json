{
	"name": "al-perf",
	"version": "3.0.0",
	"description": "CLI tool and MCP server for analyzing Business Central .alcpuprofile files",
	"type": "module",
	"main": "src/index.ts",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./src/index.ts"
		}
	},
	"bin": {
		"al-profile": "src/cli/index.ts",
		"al-profile-mcp": "src/mcp/index.ts"
	},
	"files": [
		"src/**/*.ts",
		"dist/**/*.d.ts"
	],
	"scripts": {
		"dev": "bun run src/cli/index.ts",
		"build": "tsc",
		"prepublishOnly": "bun run build",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"web": "bun run web/server.ts",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"check": "biome check --write .",
		"verify": "biome check . && tsc --noEmit && bun test"
	},
	"keywords": [
		"business-central",
		"al",
		"performance",
		"profiler",
		"mcp",
		"alcpuprofile"
	],
	"license": "GPL-3.0-only",
	"author": "SShadowS",
	"repository": {
		"type": "git",
		"url": "https://github.com/SShadowS/al-perf.git"
	},
	"homepage": "https://github.com/SShadowS/al-perf",
	"engines": {
		"bun": ">=1.0.0"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.113.0",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"chalk": "^5.6.2",
		"cli-table3": "^0.6.5",
		"commander": "^15.0.0",
		"marked": "^18.0.6",
		"web-tree-sitter": "^0.26.10",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"bun-types": "^1.3.14",
		"typescript": "^7.0.2"
	},
	"overrides": {
		"@hono/node-server": "^1.19.10",
		"body-parser": "^2.3.0",
		"express-rate-limit": "^8.5.2",
		"fast-uri": "^3.1.2",
		"hono": "^4.12.28",
		"ip-address": "^10.2.0",
		"path-to-regexp": "^8.4.2",
		"qs": "^6.15.3"
	}
}
